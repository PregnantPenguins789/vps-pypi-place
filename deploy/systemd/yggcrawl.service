[Unit]
Description=YggCrawl — PyPI Place mesh broadcaster
After=network-online.target yggdrasil.service
Wants=network-online.target yggdrasil.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/anonymous/yggcrawl
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 /home/anonymous/yggcrawl/cli.py run --loop
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
